{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Django: Run Server",
            "type": "shell",
            "command": "docker-compose up",
            "presentation": { "reveal": "always", "panel": "new" },
            "group": { "kind": "build", "isDefault": true }
        },
        {
            "label": "Django: Make Migrations",
            "type": "shell",
            "command": "docker-compose run web python manage.py makemigrations && docker-compose run web python manage.py migrate"
        }
    ]
}